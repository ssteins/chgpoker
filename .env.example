# Okta Authentication Configuration
OKTA_ISSUER=https://your-domain.okta.com/oauth2/default
OKTA_CLIENT_ID=your-okta-application-client-id
OKTA_CLIENT_SECRET=your-okta-application-client-secret

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-minimum-256-bits

# Application URLs (update with your Render URLs)
FRONTEND_URL=https://pointing-poker-frontend.onrender.com
BACKEND_URL=https://pointing-poker-backend.onrender.com

# Server Configuration
NODE_ENV=production
PORT=10000

# Development URLs (for local development)
# FRONTEND_URL=http://localhost:8080
# BACKEND_URL=http://localhost:3001